{
  "$schema": "gen/schemas/desktop-schema.json",
  "productName": "NoSubVOD",
  "version": "0.3.0",
  "identifier": "com.nosubvod.desktop",
  "build": {
    "frontendDist": "../dist/renderer",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NoSubVOD",
        "width": 600,
        "height": 700,
        "resizable": false,
        "fullscreen": false,
        "backgroundColor": "#18181b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://static-cdn.jtvnw.net https://clips-media-assets2.twitch.tv; media-src 'self' blob:; connect-src 'self'; font-src 'self'; frame-src 'none'; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["../dist/portal"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
